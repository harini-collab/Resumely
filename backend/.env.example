# Server
PORT=5000
NODE_ENV=development

# Required in production
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/resumely
JWT_SECRET=generate_with_node_-e_"console.log(require('crypto').randomBytes(64).toString('hex'))"

# Auth
JWT_EXPIRES_IN=7d

# Frontend (required in production for CORS + password reset links)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Startup behaviour (set true on Render so deploy fails if DB is unreachable)
REQUIRE_DB_ON_START=false

# Local dev only — ignored when NODE_ENV=production
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/resumely

# OpenAI (required for AI resume features)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Cloudinary (optional — resumes stored in UPLOAD_DIR if not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=resumely

# File uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=/tmp/resumely-uploads

# Email (optional — reset links log to console when SMTP is not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
